# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── JWT ─────────────────────────────────────────────────────────────────────
# SECURITY: Must be at least 32 chars with high entropy. Must be DIFFERENT from each other.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-at-least-32-unique-characters-high-entropy
JWT_REFRESH_SECRET=replace-with-different-32-unique-characters-high-entropy
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Optional: customize JWT issuer/audience for multi-service setups
JWT_ISSUER=zunacrm-api
JWT_AUDIENCE=zunacrm-app

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Primary frontend origin
FRONTEND_URL=http://localhost:5173
# Additional allowed origins (comma-separated). FRONTEND_URL is always included.
# ALLOWED_ORIGINS=http://localhost:5173,https://app.zunacrm.com

# ─── Rate Limiting (optional overrides) ──────────────────────────────────────
# AUTH_RATE_LIMIT_MAX=5            # Max failed auth attempts per window (default: 5)
# AUTH_RATE_LIMIT_WINDOW_MS=900000 # Window in ms: 15 minutes (default)
# API_RATE_LIMIT_MAX=200           # Max API requests per minute (default: 200)
# API_RATE_LIMIT_WINDOW_MS=60000   # Window in ms: 1 minute (default)

# ─── Security ────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── SMTP (Email) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
# Use an App Password for Gmail, not your real password
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Zuna CRM <noreply@zunacrm.com>
